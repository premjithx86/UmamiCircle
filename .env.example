CLOUDINARY_API_SECRET=your_api_secret
SIGHTENGINE_API_USER=your_user_id
SIGHTENGINE_API_SECRET=your_api_secret

# Security
JWT_ADMIN_SECRET=your_super_secret_jwt_key

# Network
PORT=8080
FRONTEND_URL=http://localhost:5173
