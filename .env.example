# Database
MONGO_URI=mongodb://localhost:27017/umamicircle

# Firebase
# Minified JSON string of your Firebase Service Account key
FIREBASE_SERVICE_ACCOUNT={"type": "service_account", ...}

# AI Services
GROQ_API_KEY=your_groq_key
